{
  "version": 1,
  "scope": "public/js/**/*.js",
  "updatedAt": "2026-04-28",
  "normalization": {
    "pathParams": ":param",
    "query": "?:query"
  },
  "defaults": {
    "auth": "see route middleware",
    "request": "GET/DELETE have no JSON body; POST/PUT/PATCH use the vanilla form payload for that route",
    "response": "JSON unless the route is a print/report endpoint or returns 204"
  },
  "notes": [
    "This file is the checked contract for the vanilla public UI, not the client-web frontend.",
    "The checker treats :param as a dynamic path segment and ?:query as an optional query string.",
    "Literal step endpoints such as /steps/by-code/weighing are kept because they appear literally in public/js."
  ],
